# Mission Control API
# Copy to .env and fill in values for live LLM runs.
#
# Backend selection (auto-detected if not set):
#   fireworks    → Fireworks AI serverless (requires FIREWORKS_API_KEY)
#   openrouter   → OpenRouter API (requires OPENROUTER_API_KEY)
#   vllm         → vLLM OpenAI-compatible server (requires GEMMA_ENDPOINT)
#   transformers → Local model via PyTorch/HuggingFace (requires HF_TOKEN for gated models)

LLM_BACKEND=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
GEMMA_ENDPOINT=
HF_TOKEN=

# Live mode: fetch real earthquake data from USGS instead of simulated events
LIVE_MODE=
